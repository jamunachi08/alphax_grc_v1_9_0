  {
   "role": "Compliance Officer",
   "read": 1,
   "write": 1,
   "create": 1
  },
  {
   "role": "GRC Auditor",
   "read": 1,
   "write": 1,
   "create": 1
  },
  {
   "role": "GRC Executive",
   "read": 1
  }
 ],
