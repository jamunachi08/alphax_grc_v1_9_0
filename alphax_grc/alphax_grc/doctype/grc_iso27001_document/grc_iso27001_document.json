   "in_list_view": 1
  },
  {
   "fieldname": "control_area",
   "fieldtype": "Select",
   "label": "Control Area",
   "options": "\nA.5 Organizational Controls\nA.6 People Controls\nA.7 Physical Controls\nA.8 Technological Controls\nClause 4-10 ISMS"
  },
  {
   "fieldname": "document_type",
   "fieldtype": "Select",
   "label": "Document Type",
   "options": "\nPolicy\nProcedure\nRecord\nPlan\nRegister\nManual\nAssessment\nReport\nChecklist\nTemplate"
